rules_version = '2';

// Reglas de Cloud Storage para Farmatime.
//
// Rutas usadas por la app:
//   - companies/{ownerUid}/...  → logo de empresa y avatar de empleado
//     (employee_account sube a companies/{employeeUid})
//   - employees/{employeeUid}/... → foto de perfil de empleado
//
// Lectura: cualquier usuario autenticado (logos/fotos se muestran en chat,
// dashboard y perfiles). Escritura: solo el dueño del prefijo (su propio uid).
service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(ownerUid) {
      return request.auth != null && request.auth.uid == ownerUid;
    }

    // Límite de tamaño y tipo de imagen para subidas.
    function isValidImage() {
      return request.resource.size < 8 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    match /companies/{ownerUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(ownerUid) && isValidImage();
    }

    match /employees/{employeeUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(employeeUid) && isValidImage();
    }

    // Por defecto: denegar.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
