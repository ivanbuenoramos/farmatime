{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "farmatime-app",
          "appId": "1:1079606530132:android:8faa11643cb4ef18f29dc1",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "farmatime-app",
          "appId": "1:1079606530132:ios:d1af08572b4f5bc6f29dc1",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "farmatime-app",
          "configurations": {
            "android": "1:1079606530132:android:8faa11643cb4ef18f29dc1",
            "ios": "1:1079606530132:ios:d1af08572b4f5bc6f29dc1"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.4",
    "sendgrid-mailer": "firebase/firestore-send-email@0.2.4"
  }
}
