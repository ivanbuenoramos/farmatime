# Producción.
# Las credenciales sensibles (APPLE_IAP_KEY_ID, APPLE_IAP_ISSUER_ID,
# APPLE_IAP_PRIVATE_KEY, GOOGLE_PLAY_SERVICE_ACCOUNT) viven en Secret Manager
# (declaradas en index.js -> setGlobalOptions.secrets). NO ponerlas aquí también:
# Cloud Run rechaza una misma clave como secreto y como env var a la vez.
APPLE_ENV=production
# OJO: Pub/Sub prohíbe nombres de topic que empiecen por "goog". Por eso este
# topic NO puede llamarse "google-play-notifications".
GOOGLE_PLAY_PUBSUB_TOPIC=play-rtdn-notifications
